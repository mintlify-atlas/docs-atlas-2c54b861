  "keyFeatures": [
    "Database-per-tenant multi-tenancy with dynamic connection resolution",
    "JWT-based authentication with HttpOnly cookie session management",
    "YARP-based API gateway that injects X-Company-Id header for downstream services",
    "Three independent .NET microservices: GSMAuth, GSMApplication, GSMOperations",
    "React 19 SPA with React Router v7, Tailwind CSS v4, and i18next (EN/ES)",
    "Per-tenant CSS theming resolved at login via JsonStyles stored in the registry database",
    "Productivity workflow: multi-step wizard for assigning employees to herb harvest transactions",
    "Integration engine supporting configurable API rules for external service calls",
    "Docker Compose orchestration for local development and production deployment",
    "CI/CD via GitHub Actions deploying to AWS (ECS for services, S3+CloudFront for frontend)"
  ],
  "publicApiSurface": [
    "POST /api/security/v1/auth/login",
    "POST /api/security/v1/auth/logout",
    "POST /api/security/v1/tenant/resolve",
    "GET  /api/application/v1/application/getMenu",
