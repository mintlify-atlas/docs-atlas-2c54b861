    "PUT  /api/application/v1/integrations/api-rules/{idApiRule}",
    "DELETE /api/application/v1/integrations/api-rules/{idApiRule}",
    "GET  /api/operations/v1/operations/parameters",
    "GET  /api/operations/v1/operations/master-products",
    "GET  /api/operations/v1/operations/filtered-employees",
    "GET  /api/operations/v1/operations/filtered-suppliers",
    "GET  /api/operations/v1/operations/categories",
    "GET  /api/operations/v1/operations/sku-definitions",
    "POST /api/operations/v1/operations/create-trx",
    "PATCH /api/operations/v1/operations/{idTrxHeader}",
    "POST /api/operations/v1/operations/getTrx",
    "POST /api/operations/v1/integrations/exec-api"
  ]
